PROJECT_NAME=SentinelOps AI
APP_ENV=development
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
POSTGRES_SERVER=postgres
POSTGRES_PORT=5432
POSTGRES_DB=sentinelops
POSTGRES_USER=sentinelops
POSTGRES_PASSWORD=sentinelops-dev
REDIS_URL=redis://redis:6379/0
QDRANT_URL=http://qdrant:6333
PROMETHEUS_URL=http://prometheus:9090
GRAFANA_URL=http://grafana:3000
LOKI_URL=http://loki:3100
TEMPO_URL=http://tempo:3200
TOPOLOGY_PATH=configs/development/topology.yaml
GITHUB_API_URL=https://api.github.com
GITHUB_TOKEN=replace-with-your-github-token
SLACK_WEBHOOK_URL=
APPROVAL_TIMEOUT_MINUTES=15
APPROVAL_AUTO_REJECT_MINUTES=30
API_RATE_LIMIT_PER_MINUTE=120
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2
DEFAULT_AGENT_TIMEOUT_SECONDS=30
LLM_BASE_URL=http://host.docker.internal:11434/v1
LLM_API_KEY=replace-with-your-openai-key
LLM_MODEL=gpt-4.1-mini
LLM_SECONDARY_BASE_URL=
LLM_SECONDARY_API_KEY=
LLM_SECONDARY_MODEL=gpt-4.1-mini
LLM_LOCAL_BASE_URL=http://host.docker.internal:11434/v1
LLM_LOCAL_MODEL=llama3.2
AUTH0_DOMAIN=sentinelops.local
AUTH0_AUDIENCE=sentinelops-api
AUTH0_ALGORITHMS=HS256
AUTH0_SECRET_KEY=sentinelops-dev-auth-secret
APPROVAL_TOKEN_SECRET=sentinelops-dev-approval-secret
TOOL_ALLOWLIST_PATH=configs/production/tool_allowlist.yaml
BACKUP_ONCALL_TARGETS=backup-oncall
QDRANT_PATTERN_COLLECTION=patterns
QDRANT_INCIDENT_COLLECTION=past_incidents
QDRANT_RUNBOOK_COLLECTION=runbooks
QDRANT_PREVENTION_COLLECTION=prevention_items
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
INTERNAL_API_BASE_URL=http://api-server:8000
